# ============================================
# MediGuide AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get these from Azure AI Foundry (ai.azure.com)
# See README.md for detailed setup instructions.
# ============================================

# Your Azure OpenAI endpoint URL
# Example: https://your-resource-name.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Your Azure OpenAI API key
AZURE_OPENAI_KEY=

# The name of your deployed model in Azure AI Foundry
# Common options: gpt-4o, gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API version (usually no need to change)
AZURE_OPENAI_API_VERSION=2024-02-01

AZURE_TRANSLATOR_ENDPOINT=
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=



AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=


COSMOSDB_ACCOUNT_URI=
COSMOSDB_ACCOUNT_KEY=
COSMOSDB_DATABASE_NAME=
COSMOSDB_CONTAINER_NAME=

# Flask session secret (set a strong value in production for landing-page auth)
# FLASK_SECRET_KEY=